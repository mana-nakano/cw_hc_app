# --- ステージ1: フロントエンドのビルド ---
# 18 から 20 にアップグレードしました
FROM node:20 AS frontend-builder
WORKDIR /app/frontend

COPY frontend/package*.json ./
RUN npm install
COPY frontend/ ./
RUN npm run build

# --- ステージ2: バックエンドの準備 ---
# ここも 20 に合わせます
FROM node:20 AS backend-builder
WORKDIR /app/backend
COPY backend/package*.json ./
RUN npm install
COPY backend/ ./

# --- ステージ3: 最終的な実行用イメージ ---
# 実行環境も 20 にします
FROM node:20-slim
WORKDIR /app

COPY --from=frontend-builder /app/frontend/dist ./dist
COPY --from=backend-builder /app/backend ./backend

WORKDIR /app/backend
RUN npm install --production

EXPOSE 8080
CMD ["node", "index.js"]