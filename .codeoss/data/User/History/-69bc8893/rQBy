# --- ステージ1: フロントエンドのビルド ---
FROM node:18 AS frontend-builder
WORKDIR /app/frontend
# 依存関係のみ先にコピー（キャッシュ効率化）
COPY frontend/package*.json ./
RUN npm install
# 残りのファイルをコピーしてビルド
COPY frontend/ ./
RUN npm run build

# --- ステージ2: バックエンドの準備 ---
FROM node:18 AS backend-builder
WORKDIR /app/backend
COPY backend/package*.json ./
RUN npm install
COPY backend/ ./

# --- ステージ3: 最終的な実行用イメージ ---
FROM node:18-slim
WORKDIR /app

# ビルド済みのフロントエンド（dist）をコピー
COPY --from=frontend-builder /app/frontend/dist ./dist
# バックエンドのソースをコピー
COPY --from=backend-builder /app/backend ./backend

# 本番用のライブラリだけをインストール
WORKDIR /app/backend
RUN npm install --production

# ポート設定と起動
EXPOSE 8080
CMD ["node", "index.js"]